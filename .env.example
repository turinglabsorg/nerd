# MongoDB
MONGODB_URI=mongodb://localhost:27017/nerd

# Reddit — subreddits to watch (comma-separated)
SUBREDDITS=technology,artificial,machinelearning

# Reddit — optional keyword filter (comma-separated, matches in title)
KEYWORDS=

# Cron schedule (default: every 5 minutes)
CRON_POSTS=*/5 * * * *
CRON_COMMENTS=*/7 * * * *
CRON_EVALUATE=*/10 * * * *

# Max posts per subreddit per fetch
POSTS_LIMIT=25

# Claude Code binary path (if not in PATH)
CLAUDE_BIN=claude

# Base URL for post links (used in Telegram messages)
BASE_URL=https://nerd-828110571677.europe-west1.run.app
